---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const base = import.meta.env.BASE_URL;
---

<Layout title="Erfolgsgeschichten | Portfolio">
  <h1 class="text-4xl font-bold mb-2">Erfolgsgeschichten</h1>
  <p class="text-neutral-400 mb-12">Nachhaltig zum Erfolg.</p>

  <!-- Erfolgsgeschichten -->
  <section class="py-12 border-t border-neutral-800">
    <h2 class="text-2xl font-semibold mb-8">Erfolgsgeschichten</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Samuel -->
      <div class="bg-neutral-800 rounded-xl overflow-hidden flex flex-col">
        <div
          class="aspect-video w-full bg-neutral-700 flex items-center justify-center"
        >
          <span class="text-neutral-600 text-sm">Samuel (18)</span>
        </div>
        <div class="p-5 flex flex-col gap-2">
          <h3 class="text-base font-semibold leading-snug">Samuel (18)</h3>
          <p class="text-sm text-neutral-400 leading-relaxed">
            Samuel konnte sein Training mithilfe von Struktur wesentlich
            effizienter gestalten. Er Trainiert heute weniger als je zuvor und
            baut weiterhin Muskeln auf.
            <br /><br />
            Er hat gelernt, dass es nicht darum geht, möglichst viel zu trainieren,
            sondern das Training so zu gestalten, dass es zum Leben passt und gleichzeitig
            Fortschritte ermöglicht.
          </p>
        </div>
      </div>
      <!-- Platzhalter 2 -->
      <div class="bg-neutral-800 rounded-xl overflow-hidden flex flex-col">
        <div
          class="aspect-video w-full bg-neutral-700 flex items-center justify-center"
        >
          <span class="text-neutral-600 text-sm">Karin (43)</span>
        </div>
        <div class="p-5 flex flex-col gap-2">
          <h3 class="text-base font-semibold leading-snug">Karin (43)</h3>
          <p class="text-sm text-neutral-400 leading-relaxed">
            Kathrin kam mit wenig Sporterfahrung zu mir, hatte aber das mutige
            Ziel, ein Spartan Race zu absolvieren.
            <br /><br />
            Wir haben ihr körperliches Fundament von Grund auf aufgebaut und die wöchentliche
            Belastung an ihren Alltag angepasst.
            <br /><br />
            Aus der Anfängerin ist eine leistungsfähige Athletin geworden, die heute
            topfit an der Startlinie für einen Hindernislauf stehen kann.
          </p>
        </div>
      </div>
      <!-- Platzhalter 3 -->
      <div
        class="bg-neutral-800 rounded-xl overflow-hidden flex flex-col sm:col-span-2 lg:col-span-1"
      >
        <div
          class="aspect-video w-full bg-neutral-700 flex items-center justify-center"
        >
          <span class="text-neutral-600 text-sm">Person 3</span>
        </div>
        <div class="p-5 flex flex-col gap-2">
          <h3 class="text-base font-semibold leading-snug">Person 3</h3>
          <p class="text-sm text-neutral-400 leading-relaxed">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do
            eiusmod tempor incididunt ut labore et dolore magna aliqua.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
