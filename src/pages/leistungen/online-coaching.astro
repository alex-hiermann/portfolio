---
import Layout from "../../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout
    title="1:1 Online Coaching | Benedikt Trcka"
    description="1:1 Online Coaching von Benedikt Trcka — individuelle Trainingspläne, wöchentliche Check-Ins und datenbasiertes Coaching. Flexibel, österreichweit."
>
    <!-- Hero -->
    <section class="py-16 md:py-24 border-b border-neutral-800">
        <p class="text-sm text-neutral-500 uppercase tracking-widest mb-4">
            Leistung
        </p>
        <h1
            class="text-4xl md:text-6xl font-bold tracking-tight mb-6 max-w-3xl"
        >
            1:1 Online Coaching
        </h1>
        <p
            class="text-lg md:text-xl text-neutral-400 max-w-2xl leading-relaxed mb-8"
        >
            Maximale Flexibilität gepaart mit kompromissloser Struktur. Egal, wo
            und wann du trainierst – wir steuern deinen Fortschritt präzise über
            die App. Ein komplett datenbasiertes Coaching für messbare
            Ergebnisse, ohne örtliche Gebundenheit.
        </p>
        <a
            href={`${base}contact`}
            class="magnetic inline-block px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors"
        >
            Erstgespräch vereinbaren
        </a>
    </section>

    <!-- Steps -->
    <section class="py-16">
        <div class="flex flex-col gap-0 divide-y divide-neutral-800">
            <!-- Step 1 -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-12 py-12">
                <div class="flex-shrink-0 flex items-start gap-4 md:w-56">
                    <span
                        class="text-3xl font-bold text-neutral-500 select-none leading-none"
                        >01</span
                    >
                    <!-- Icon: Video / Camera -->
                    <svg
                        class="w-8 h-8 text-white mt-0.5 flex-shrink-0"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14v-4z"
                        ></path>
                        <rect x="3" y="8" width="12" height="8" rx="2"></rect>
                    </svg>
                </div>
                <div class="flex flex-col gap-3">
                    <h2 class="text-xl md:text-2xl font-semibold">
                        Video-Analyse & Check-ins
                    </h2>
                    <p class="text-neutral-400 leading-relaxed max-w-2xl">
                        Du filmst deine Arbeitssätze, ich analysiere deine
                        Biomechanik aus der Ferne. Durch unsere wöchentlichen
                        Check-ins werten wir deine Performance-Daten aus und
                        passen dein System sofort an,
                        <span class="text-white font-medium"
                            >sobald sich dein Körper verändert.</span
                        >
                    </p>
                    <div class="flex flex-wrap gap-3 mt-1">
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Biomechanik-Analyse</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Wöchentliche Check-ins</span
                        >
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-12 py-12">
                <div class="flex-shrink-0 flex items-start gap-4 md:w-56">
                    <span
                        class="text-3xl font-bold text-neutral-500 select-none leading-none"
                        >02</span
                    >
                    <!-- Icon: Clipboard / Assessment -->
                    <svg
                        class="w-8 h-8 text-white mt-0.5 flex-shrink-0"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"
                        ></path>
                        <rect x="9" y="3" width="6" height="4" rx="1"></rect>
                        <line x1="9" y1="12" x2="15" y2="12"></line>
                        <line x1="9" y1="16" x2="13" y2="16"></line>
                    </svg>
                </div>
                <div class="flex flex-col gap-3">
                    <h2 class="text-xl md:text-2xl font-semibold">
                        Digitales Assessment
                    </h2>
                    <p class="text-neutral-400 leading-relaxed max-w-2xl">
                        Wir starten mit einem digitalen Assessment. Wir werten
                        deinen Alltag, deine Ernährung und dein aktuelles
                        Leistungslevel im Detail aus.
                        <span class="text-white font-medium"
                            >Auf diesen harten Fakten basierend</span
                        > konstruiere ich dein maßgeschneidertes Trainingssystem.
                    </p>
                    <div class="flex flex-wrap gap-3 mt-1">
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Ernährungsanalyse</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Leistungsdiagnose</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Individuelles System</span
                        >
                    </div>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-12 py-12">
                <div class="flex-shrink-0 flex items-start gap-4 md:w-56">
                    <span
                        class="text-3xl font-bold text-neutral-500 select-none leading-none"
                        >03</span
                    >
                    <!-- Icon: Phone / App -->
                    <svg
                        class="w-8 h-8 text-white mt-0.5 flex-shrink-0"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="5" y="2" width="14" height="20" rx="2"></rect>
                        <line x1="12" y1="18" x2="12.01" y2="18"></line>
                    </svg>
                </div>
                <div class="flex flex-col gap-3">
                    <h2 class="text-xl md:text-2xl font-semibold">
                        Strukturiertes App-Training
                    </h2>
                    <p class="text-neutral-400 leading-relaxed max-w-2xl">
                        Du trainierst zeitlich flexibel, aber mit klarem
                        Bauplan. In der App findest du deine Workouts inklusive
                        detaillierter Übungsvideos und meinen genauen
                        Technik-Hinweisen.
                        <span class="text-white font-medium"
                            >Du weißt immer exakt, welches Gewicht und wie viele
                            Wiederholungen heute anstehen.</span
                        >
                    </p>
                    <div class="flex flex-wrap gap-3 mt-1">
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Übungsvideos</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Technik-Hinweise</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Örtlich unabhängig</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-12 border-t border-neutral-800">
        <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6"
        >
            <div>
                <h2 class="text-2xl font-semibold mb-1">Bereit anzufangen?</h2>
                <p class="text-neutral-400">
                    Schreib mir — das Erstgespräch ist kostenlos.
                </p>
            </div>
            <a
                href={`${base}contact`}
                class="magnetic flex-shrink-0 px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors text-center"
            >
                Jetzt Kontakt aufnehmen
            </a>
        </div>
    </section>

    <!-- Back -->
    <div class="pb-12">
        <a
            href={base}
            class="text-sm text-neutral-500 hover:text-white transition-colors"
        >
            ← Zurück zur Startseite
        </a>
    </div>
</Layout>

<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "Startseite",
                        "item": "https://alex-hiermann.github.io/portfolio/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "name": "Leistungen",
                        "item": "https://alex-hiermann.github.io/portfolio/leistungen/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 3,
                        "name": "1:1 Online Coaching",
                        "item": "https://alex-hiermann.github.io/portfolio/leistungen/online-coaching/"
                    }
                ]
            },
            {
                "@type": "Service",
                "name": "1:1 Online Coaching",
                "description": "Individuelle Trainingspläne, wöchentliche Check-Ins und Übungsvideos — flexibel und österreichweit. Datenbasiertes Online Coaching von Benedikt Trcka.",
                "provider": { "@type": "Person", "name": "Benedikt Trcka" },
                "areaServed": "Österreich",
                "serviceType": "Online Fitness Coaching",
                "url": "https://alex-hiermann.github.io/portfolio/leistungen/online-coaching/"
            }
        ]
    }
</script>
