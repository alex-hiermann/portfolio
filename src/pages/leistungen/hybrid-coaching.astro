---
import Layout from "../../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout
    title="1:1 Hybrid Coaching | Benedikt Trcka"
    description="1:1 Hybrid Coaching von Benedikt Trcka in Bruck an der Leitha — Personal Training vor Ort kombiniert mit datenbasierter App-Begleitung. Technik. Daten. Ergebnisse."
>
    <!-- Hero -->
    <section class="py-16 md:py-24 border-b border-neutral-800">
        <p class="text-sm text-neutral-500 uppercase tracking-widest mb-4">
            Leistung
        </p>
        <h1
            class="text-4xl md:text-6xl font-bold tracking-tight mb-6 max-w-3xl"
        >
            1:1 Hybrid Coaching
        </h1>
        <p
            class="text-lg md:text-xl text-neutral-400 max-w-2xl leading-relaxed mb-8"
        >
            Die perfekte Symbiose aus Personal Training und smarter
            App-Begleitung. Wir perfektionieren deine Technik persönlich vor Ort
            und steuern deinen Fortschritt datenbasiert. Ein System, das bei
            konsequenter Umsetzung Erfolge garantiert.
        </p>
        <a
            href={`${base}contact`}
            class="magnetic inline-block px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors"
        >
            Erstgespräch vereinbaren
        </a>
    </section>

    <!-- Steps -->
    <section class="py-16">
        <div class="flex flex-col gap-0 divide-y divide-neutral-800">
            <!-- Step 1 -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-12 py-12">
                <div class="flex-shrink-0 flex items-start gap-4 md:w-56">
                    <span
                        class="text-3xl font-bold text-neutral-500 select-none leading-none"
                        >01</span
                    >
                    <!-- Icon: Target / Kickoff -->
                    <svg
                        class="w-8 h-8 text-white mt-0.5 flex-shrink-0"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="12" cy="12" r="10"></circle>
                        <circle cx="12" cy="12" r="6"></circle>
                        <circle cx="12" cy="12" r="2"></circle>
                    </svg>
                </div>
                <div class="flex flex-col gap-3">
                    <h2 class="text-xl md:text-2xl font-semibold">
                        Kickoff & Analyse
                    </h2>
                    <p class="text-neutral-400 leading-relaxed max-w-2xl">
                        Wir starten mit einem detaillierten Kickoff. Wir
                        analysieren deinen aktuellen Ist-Zustand, decken
                        biomechanische Schwachstellen auf und setzen ein
                        messbares Ziel für unsere Zusammenarbeit.
                        <span class="text-white font-medium">
                            Kein Raten, nur Fakten.</span
                        >
                    </p>
                    <div class="flex flex-wrap gap-3 mt-1">
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Ist-Analyse</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Biomechanik-Check</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Messbares Ziel</span
                        >
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-12 py-12">
                <div class="flex-shrink-0 flex items-start gap-4 md:w-56">
                    <span
                        class="text-3xl font-bold text-neutral-500 select-none leading-none"
                        >02</span
                    >
                    <!-- Icon: Dumbbell / Live Sessions -->
                    <svg
                        class="w-8 h-8 text-white mt-0.5 flex-shrink-0"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M6 4v16M18 4v16"></path>
                        <path d="M3 8h3M18 8h3M3 16h3M18 16h3"></path>
                        <path d="M6 12h12"></path>
                    </svg>
                </div>
                <div class="flex flex-col gap-3">
                    <h2 class="text-xl md:text-2xl font-semibold">
                        Live-Sessions & App-Training
                    </h2>
                    <p class="text-neutral-400 leading-relaxed max-w-2xl">
                        In unseren persönlichen Live-Sessions optimieren wir
                        deine Übungsausführung an den Gewichten. Den restlichen
                        Monat trainierst du zeitlich flexibel, aber zu 100 %
                        strukturiert nach deinem maßgeschneiderten Plan in der
                        App.
                    </p>
                    <div class="flex flex-wrap gap-3 mt-1">
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Technik-Optimierung</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Maßgeschneiderter Plan</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Zeitlich flexibel</span
                        >
                    </div>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-12 py-12">
                <div class="flex-shrink-0 flex items-start gap-4 md:w-56">
                    <span
                        class="text-3xl font-bold text-neutral-500 select-none leading-none"
                        >03</span
                    >
                    <!-- Icon: Chart / Tracking -->
                    <svg
                        class="w-8 h-8 text-white mt-0.5 flex-shrink-0"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"
                        ></polyline>
                    </svg>
                </div>
                <div class="flex flex-col gap-3">
                    <h2 class="text-xl md:text-2xl font-semibold">
                        Tracking & Optimierung
                    </h2>
                    <p class="text-neutral-400 leading-relaxed max-w-2xl">
                        Zufall wird ausgeschlossen. Über wöchentliche Check-ins
                        und die Auswertung deiner Trainingsdaten tracken wir
                        deine Performance durchgehend.
                        <span class="text-white font-medium">
                            Stagnierst du, passen wir die Parameter sofort an</span
                        >
                        — bis das Ziel erreicht ist.
                    </p>
                    <div class="flex flex-wrap gap-3 mt-1">
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Wöchentliche Check-ins</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Datenbasiert</span
                        >
                        <span
                            class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                            >Laufende Anpassung</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-12 border-t border-neutral-800">
        <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6"
        >
            <div>
                <h2 class="text-2xl font-semibold mb-1">Bereit anzufangen?</h2>
                <p class="text-neutral-400">
                    Schreib mir — das Erstgespräch ist kostenlos.
                </p>
            </div>
            <a
                href={`${base}contact`}
                class="magnetic flex-shrink-0 px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors text-center"
            >
                Jetzt Kontakt aufnehmen
            </a>
        </div>
    </section>

    <!-- Back -->
    <div class="pb-12">
        <a
            href={base}
            class="text-sm text-neutral-500 hover:text-white transition-colors"
        >
            ← Zurück zur Startseite
        </a>
    </div>
</Layout>

<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "Startseite",
                        "item": "https://alex-hiermann.github.io/portfolio/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "name": "Leistungen",
                        "item": "https://alex-hiermann.github.io/portfolio/leistungen/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 3,
                        "name": "1:1 Hybrid Coaching",
                        "item": "https://alex-hiermann.github.io/portfolio/leistungen/hybrid-coaching/"
                    }
                ]
            },
            {
                "@type": "Service",
                "name": "1:1 Hybrid Coaching",
                "description": "Personal Training vor Ort kombiniert mit datenbasierter App-Begleitung. Kickoff-Analyse, Live-Sessions, wöchentliches Tracking.",
                "provider": { "@type": "Person", "name": "Benedikt Trcka" },
                "areaServed": "Bruck an der Leitha, Niederösterreich",
                "serviceType": "Personal Training & Fitness Coaching",
                "url": "https://alex-hiermann.github.io/portfolio/leistungen/hybrid-coaching/"
            }
        ]
    }
</script>
