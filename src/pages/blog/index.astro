---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const base = import.meta.env.BASE_URL;
---

<Layout title="Blog | Portfolio">
  <h1 class="text-4xl font-bold mb-2">Blog</h1>
  <p class="text-neutral-400 mb-12">Gedanken, Projekte, Einblicke.</p>

  {
    posts.length === 0 ? (
      <p class="text-neutral-500">
        Noch keine Einträge. Füge `.md`-Dateien in{" "}
        <code class="text-neutral-300">src/content/blog/</code> hinzu.
      </p>
    ) : (
      <ul class="flex flex-col divide-y divide-neutral-800">
        {posts.map((post) => (
          <li>
            <a
              href={`${base}blog/${post.id}`}
              class="group flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-6 py-6"
            >
              <span class="text-xs text-neutral-500 shrink-0 w-36">
                {post.data.date.toLocaleDateString("de-DE", {
                  day: "2-digit",
                  month: "long",
                  year: "numeric",
                })}
              </span>
              <div>
                <p class="font-medium group-hover:text-neutral-300 transition-colors">
                  {post.data.title}
                </p>
                <p class="text-sm text-neutral-400 mt-1">
                  {post.data.description}
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</Layout>
