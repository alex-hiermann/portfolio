---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Impressum | Alexander Hiermann">
    <div class="max-w-2xl">
        <h1 class="text-4xl font-bold mb-10 pb-4 border-b border-neutral-800">
            Impressum
        </h1>

        <section class="mb-8">
            <h2 class="text-xl font-semibold mb-3">
                Offenlegung gemäß § 25 Mediengesetz
            </h2>
            <p class="text-neutral-400 font-medium mb-1">
                Betreiber der Website:
            </p>
            <p class="text-neutral-300">
                Alexander Hiermann<br />
                1100 Wien, Österreich
            </p>
        </section>

        <section class="mb-8">
            <h2 class="text-xl font-semibold mb-3">Kontakt</h2>
            <p class="text-neutral-300">
                E-Mail: <a
                    href="mailto:alex.hiermann@gmx.at"
                    class="text-neutral-400 hover:text-white transition-colors"
                    >alex.hiermann@gmx.at</a
                >
            </p>
        </section>

        <section class="mb-8">
            <h2 class="text-xl font-semibold mb-3">
                Grundlegende Richtung (Blattlinie)
            </h2>
            <p class="text-neutral-400 leading-relaxed">
                Diese Website stellt ein persönliches Portfolio dar. Sie dient
                der Präsentation meiner Projekte, Qualifikationen sowie meiner
                Person als Software-Entwickler.
            </p>
        </section>

        <section class="mb-8">
            <h2 class="text-xl font-semibold mb-3">Haftungsausschluss</h2>
            <p class="text-neutral-400 leading-relaxed">
                Trotz sorgfältiger inhaltlicher Kontrolle übernehme ich keine
                Haftung für die Inhalte externer Links. Für den Inhalt der
                verlinkten Seiten sind ausschließlich deren Betreiber
                verantwortlich.
            </p>
        </section>
    </div>
</Layout>
