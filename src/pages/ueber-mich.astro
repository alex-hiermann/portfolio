---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout
    title="Über mich | Benedikt Trcka"
    description="Benedikt Trcka — Personal Trainer & Fitness Coach aus Bruck an der Leitha, Niederösterreich. Strukturiertes, datenbasiertes Coaching für messbare Ergebnisse."
>
    <!-- Hero: Bild + Intro nebeneinander -->
    <section class="py-16 md:py-24">
        <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
            <!-- Bild -->
            <div class="w-full lg:w-2/5 flex-shrink-0">
                <div
                    class="relative rounded-2xl overflow-hidden aspect-[3/4] bg-[rgb(40,40,40)]"
                >
                    <img
                        src={`${base}images/oberk-farbe.png`}
                        alt="Benedikt Trcka"
                        class="w-full h-full object-cover grayscale object-top"
                        width="1080"
                        height="1080"
                        loading="lazy"
                        decoding="async"
                    />
                    <!-- subtiler Gradient unten -->
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black to-transparent"
                    >
                    </div>
                </div>
            </div>

            <!-- Text -->
            <div class="flex flex-col gap-8 lg:pt-4">
                <div>
                    <p
                        class="text-sm text-neutral-500 uppercase tracking-widest mb-4"
                    >
                        Über mich
                    </p>
                    <h1
                        class="text-4xl md:text-5xl font-bold tracking-tight mb-6"
                    >
                        BENEDIKT TRCKA
                    </h1>
                    <p class="text-neutral-400 text-base leading-relaxed">
                        Personal Trainer & Fitness Coach aus Bruck an der
                        Leitha, Niederösterreich.
                    </p>
                </div>

                <div
                    class="flex flex-col gap-5 text-neutral-400 leading-relaxed"
                >
                    <p>
                        Als angehender Ingenieur für Erneuerbare Energien
                        verfolge ich einen klaren Ansatz:
                        <span class="text-white font-medium">
                            Gute Leistung entsteht nur auf einem stabilen
                            Fundament.
                        </span>
                        Was in der Technik gilt, übertrage ich konsequent auf das
                        Training — strukturiert, messbar, ohne Kompromisse.
                    </p>
                    <p>
                        Nach vielen Jahren intensiver Sporterfahrung habe ich
                        ein Coaching-Konzept für Menschen entwickelt, die wenig
                        Zeit haben, aber trotzdem Ergebnisse wollen. Besonders
                        Büroangestellte, Selbstständige und Handwerker
                        profitieren davon.
                        <span class="text-white font-medium">
                            Statt stundenlanger, planloser Workouts setze ich
                            auf effiziente Einheiten mit klarer Strategie.
                        </span>
                    </p>
                    <p>
                        Mein Versprechen: Ich begleite dich so lange, bis das
                        Ziel erreicht ist — nicht mit Motivation-Sprüchen,
                        sondern mit einem System, das funktioniert.
                    </p>
                </div>

                <div class="flex flex-wrap gap-2 pt-2">
                    <span
                        class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                        >Ingenieur-Denkweise</span
                    >
                    <span
                        class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                        >Strukturiert</span
                    >
                    <span
                        class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                        >Faktenbasiert</span
                    >
                    <span
                        class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                        >Effizient</span
                    >
                    <span
                        class="text-xs px-3 py-1 rounded-full bg-neutral-800 text-neutral-300"
                        >Ergebnisorientiert</span
                    >
                </div>

                <a
                    href={`${base}contact`}
                    class="magnetic self-start px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors"
                >
                    Erstgespräch vereinbaren
                </a>
            </div>
        </div>
    </section>

    <!-- Zahlen / Facts -->
    <section class="py-12 border-t border-neutral-800">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
            <div class="flex flex-col gap-1">
                <span
                    class="text-3xl font-bold"
                    data-count-to="10"
                    data-suffix="+">10+</span
                >
                <span class="text-sm text-neutral-500"
                    >Jahre Sport-Erfahrung</span
                >
            </div>
            <div class="flex flex-col gap-1">
                <span
                    class="text-3xl font-bold"
                    data-count-to="30"
                    data-suffix="+">30+</span
                >
                <span class="text-sm text-neutral-500">Klienten</span>
            </div>
            <div class="flex flex-col gap-1">
                <span class="text-3xl font-bold">1:1</span>
                <span class="text-sm text-neutral-500"
                    >Persönliche Betreuung</span
                >
            </div>
            <div class="flex flex-col gap-1">
                <span
                    class="text-3xl font-bold"
                    data-count-to="0"
                    data-count-from="12">0</span
                >
                <span class="text-sm text-neutral-500">Planlose Workouts</span>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-12 border-t border-neutral-800">
        <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6"
        >
            <div>
                <h2 class="text-2xl font-semibold mb-1">
                    Starten wir gemeinsam.
                </h2>
                <p class="text-neutral-400">
                    Das Erstgespräch ist kostenlos und unverbindlich.
                </p>
            </div>
            <a
                href={`${base}contact`}
                class="magnetic flex-shrink-0 px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors text-center"
            >
                Kontakt aufnehmen
            </a>
        </div>
    </section>
    <script>
        // Scroll-triggered stat counter
        const prefersReducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;
        const counters =
            document.querySelectorAll<HTMLElement>("[data-count-to]");
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (!entry.isIntersecting) return;
                    const el = entry.target as HTMLElement;
                    const to = parseInt(el.dataset.countTo ?? "0");
                    const from = parseInt(el.dataset.countFrom ?? "0");
                    const suffix = el.dataset.suffix ?? "";
                    if (prefersReducedMotion) {
                        el.textContent = to + suffix;
                        observer.unobserve(el);
                        return;
                    }
                    const duration = 1400;
                    const start = performance.now();
                    const update = (now: number) => {
                        const progress = Math.min((now - start) / duration, 1);
                        const eased = 1 - Math.pow(1 - progress, 3);
                        const current = Math.round(from + (to - from) * eased);
                        el.textContent = current + suffix;
                        if (progress < 1) requestAnimationFrame(update);
                    };
                    requestAnimationFrame(update);
                    observer.unobserve(el);
                });
            },
            { threshold: 0.6 },
        );
        counters.forEach((c) => observer.observe(c));
    </script>
</Layout>
