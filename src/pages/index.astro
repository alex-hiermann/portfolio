---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Benedikt Trcka | Personal Trainer & Fitness Coach"
  description="1:1 Personal Training und Online Coaching aus Bruck an der Leitha. Datenbasiertes Training für messbare Ergebnisse — egal ob Muskelaufbau, Kraft oder Ausdauer."
>
  <!-- Hero -->
  <section class="py-16 md:py-24 relative">
    <!-- Content -->
    <div class="relative z-10">
      <p class="text-sm text-neutral-500 uppercase tracking-widest mb-4">
        Willkommen
      </p>
      <h1
        class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-4"
      >
        BENEDIKT TRCKA
      </h1>
      <p class="text-xl md:text-2xl font-semibold text-neutral-300 mb-4">
        Du willst <span class="text-white">schwer</span> und <span
          class="text-white">richtig</span
        > trainieren?
      </p>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mb-8">
        Verändere dein Training mit dem <span class="text-white font-medium"
          >1:1 Hybrid System.</span
        >
      </p>
      <div class="flex gap-4 flex-wrap">
        <a
          href={`${base}contact`}
          class="magnetic px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors"
        >
          Erstgespräch vereinbaren
        </a>
      </div>
    </div>
  </section>

  {/* Gallery temporarily hidden */}
  {false && (
  <section class="py-12 border-t border-neutral-800">
    <h2 class="text-2xl font-semibold mb-8">Leistungen</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Karte 1 -->
      <div
        class="group relative rounded-xl overflow-hidden aspect-[3/4] bg-neutral-800 cursor-pointer"
      >
        <!-- Bild -->
        <img
          src={`${base}images/trainer-app.png`}
          alt="1:1 Hybrid Coaching"
          class="absolute inset-0 w-full h-full object-cover grayscale transition-transform duration-500 group-hover:scale-105"
          width="1080"
          height="1080"
          loading="lazy"
          decoding="async"
        />
        <!-- Gradient -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"
        >
        </div>
        <!-- Overlay-Inhalt -->
        <div class="absolute inset-x-0 bottom-0 p-5 flex flex-col">
          <!-- Collapsible: grid trick so hidden content takes no space -->
          <div
            class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] [@media(hover:none)]:grid-rows-[1fr] transition-[grid-template-rows] duration-300 overflow-hidden"
          >
            <div class="min-h-0 flex flex-col gap-3 pb-3 overflow-hidden">
              <p
                class="text-sm text-neutral-300 leading-relaxed
                opacity-0 group-hover:opacity-100 [@media(hover:none)]:opacity-100
                transition-opacity duration-300"
              >
                Mein Hybrid Coaching ist eine Mischung aus Personal Training und
                App-Begleitung. Technik vor Ort, Fortschritt datenbasiert.
              </p>
              <a
                href={`${base}leistungen/hybrid-coaching`}
                aria-label="Mehr erfahren über 1:1 Hybrid Coaching"
                class="self-start text-sm font-medium px-4 py-2 rounded-lg border border-white/30 hover:bg-white hover:text-black transition-colors
                  opacity-0 group-hover:opacity-100 [@media(hover:none)]:opacity-100
                  transition-opacity duration-300 delay-75"
              >
                Mehr erfahren →
              </a>
            </div>
          </div>
          <h3 class="text-base font-semibold leading-snug">
            1:1 Hybrid Coaching
          </h3>
        </div>
      </div>

      <!-- Karte 2 -->
      <div
        class="group relative rounded-xl overflow-hidden aspect-[3/4] bg-neutral-800 cursor-pointer"
      >
        <!-- Bild -->
        <img
          src={`${base}images/app-web-mobil.png`}
          alt="1:1 Online Coaching"
          class="absolute inset-0 w-full h-full object-cover grayscale transition-transform duration-500 group-hover:scale-105"
          width="1080"
          height="1080"
          loading="lazy"
          decoding="async"
        />
        <!-- Gradient -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"
        >
        </div>
        <!-- Overlay-Inhalt -->
        <div class="absolute inset-x-0 bottom-0 p-5 flex flex-col">
          <div
            class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] [@media(hover:none)]:grid-rows-[1fr] transition-[grid-template-rows] duration-300 overflow-hidden"
          >
            <div class="min-h-0 flex flex-col gap-3 pb-3 overflow-hidden">
              <p
                class="text-sm text-neutral-300 leading-relaxed
                opacity-0 group-hover:opacity-100 [@media(hover:none)]:opacity-100
                transition-opacity duration-300"
              >
                Individuelle Trainingspläne, wöchentliche Check-Ins und
                Übungsvideos — komplett digital per App.
              </p>
              <a
                href={`${base}leistungen/online-coaching`}
                aria-label="Mehr erfahren über 1:1 Online Coaching"
                class="self-start text-sm font-medium px-4 py-2 rounded-lg border border-white/30 hover:bg-white hover:text-black transition-colors
                  opacity-0 group-hover:opacity-100 [@media(hover:none)]:opacity-100
                  transition-opacity duration-300 delay-75"
              >
                Mehr erfahren →
              </a>
            </div>
          </div>
          <h3 class="text-base font-semibold leading-snug">
            1:1 Online Coaching
          </h3>
        </div>
      </div>

      <!-- Karte 3 -->
      <div
        class="group relative rounded-xl overflow-hidden aspect-[3/4] bg-neutral-800 cursor-pointer sm:col-span-2 lg:col-span-1"
      >
        <!-- Bild -->
        <img
          src={`${base}images/backprint.png`}
          alt="Personal Training"
          class="absolute inset-0 w-full h-full object-cover grayscale transition-transform duration-500 group-hover:scale-105"
          width="1080"
          height="1080"
          loading="lazy"
          decoding="async"
        />
        <!-- Gradient -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"
        >
        </div>
        <!-- Overlay-Inhalt -->
        <div class="absolute inset-x-0 bottom-0 p-5 flex flex-col">
          <div
            class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] [@media(hover:none)]:grid-rows-[1fr] transition-[grid-template-rows] duration-300 overflow-hidden"
          >
            <div class="min-h-0 flex flex-col gap-3 pb-3 overflow-hidden">
              <p
                class="text-sm text-neutral-300 leading-relaxed
                opacity-0 group-hover:opacity-100 [@media(hover:none)]:opacity-100
                transition-opacity duration-300"
              >
                Calisthenics, Bodybuilding, Powerlifting oder Ausdauer — 1:1
                Training individuell auf dich zugeschnitten.
              </p>
              <a
                href={`${base}leistungen/personal-training`}
                aria-label="Mehr erfahren über Personal Training"
                class="self-start text-sm font-medium px-4 py-2 rounded-lg border border-white/30 hover:bg-white hover:text-black transition-colors
                  opacity-0 group-hover:opacity-100 [@media(hover:none)]:opacity-100
                  transition-opacity duration-300 delay-75"
              >
                Mehr erfahren →
              </a>
            </div>
          </div>
          <h3 class="text-base font-semibold leading-snug">
            Personal Training
          </h3>
        </div>
      </div>
    </div>
  </section>
  )}
</Layout>
