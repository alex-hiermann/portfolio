---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const latestPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const base = import.meta.env.BASE_URL;
---

<Layout title="Portfolio">
  <!-- Hero -->
  <section class="py-16 md:py-24">
    <p class="text-sm text-neutral-500 uppercase tracking-widest mb-4">
      Willkommen
    </p>
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
      Dein Name
    </h1>
    <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mb-8">
      Kurze Beschreibung — was du machst, wer du bist, was dich antreibt.
    </p>
    <div class="flex gap-4 flex-wrap">
      <a
        href={`${base}contact`}
        class="px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors"
      >
        Kontakt aufnehmen
      </a>
      <a
        href={`${base}blog`}
        class="px-6 py-3 border border-neutral-700 rounded-lg hover:border-neutral-500 transition-colors"
      >
        Blog lesen
      </a>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-12 border-t border-neutral-800">
    <h2 class="text-2xl font-semibold mb-8">Arbeiten</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div
        class="aspect-square bg-neutral-800 rounded-xl overflow-hidden flex items-center justify-center"
      >
        <span class="text-neutral-600 text-sm">Bild 1</span>
      </div>
      <div
        class="aspect-square bg-neutral-800 rounded-xl overflow-hidden flex items-center justify-center"
      >
        <span class="text-neutral-600 text-sm">Bild 2</span>
      </div>
      <div
        class="aspect-square bg-neutral-800 rounded-xl overflow-hidden flex items-center justify-center"
      >
        <span class="text-neutral-600 text-sm">Bild 3</span>
      </div>
    </div>
  </section>

  <!-- Latest blog posts -->
  <section class="py-12 border-t border-neutral-800">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-semibold">Aktuelles</h2>
      <a
        href={`${base}blog`}
        class="text-sm text-neutral-400 hover:text-white transition-colors"
        >Alle →</a
      >
    </div>
    {
      latestPosts.length === 0 ? (
        <p class="text-neutral-500">Noch keine Einträge.</p>
      ) : (
        <ul class="flex flex-col gap-6">
          {latestPosts.map((post) => (
            <li>
              <a
                href={`${base}blog/${post.id}`}
                class="group flex flex-col gap-1"
              >
                <span class="text-xs text-neutral-500">
                  {post.data.date.toLocaleDateString("de-DE", {
                    day: "2-digit",
                    month: "long",
                    year: "numeric",
                  })}
                </span>
                <span class="text-lg font-medium group-hover:text-neutral-300 transition-colors">
                  {post.data.title}
                </span>
                <span class="text-sm text-neutral-400">
                  {post.data.description}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>
