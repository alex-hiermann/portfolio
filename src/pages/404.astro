---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout
    title="404 – Seite nicht gefunden | Benedikt Trcka"
    description="Diese Seite existiert nicht."
    noindex={true}
>
    <section
        class="py-24 md:py-40 flex flex-col items-center text-center gap-6"
    >
        <p class="text-sm text-neutral-500 uppercase tracking-widest">
            Fehler 404
        </p>
        <h1 class="text-6xl md:text-8xl font-bold tracking-tight">404</h1>
        <p class="text-xl text-neutral-400 max-w-md">
            Diese Seite existiert nicht oder wurde verschoben.
        </p>
        <a
            href={base}
            class="magnetic mt-4 px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-neutral-200 transition-colors"
        >
            Zurück zur Startseite
        </a>
    </section>
</Layout>
